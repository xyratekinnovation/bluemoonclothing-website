APP_NAME=Bluemoon Backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bluemoon
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluemoon

# Set to true for first-time deployments to create tables automatically.
AUTO_CREATE_TABLES=true

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated browser origins. MUST include every URL where your SPA runs (Vercel + custom domain).
# Custom domain example (add both www and apex if you use both):
#   https://www.houseofbluemoon.com,https://houseofbluemoon.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Extra allowed Origin pattern (regex). Default matches all https://*.vercel.app deployments only.
# Custom domains are NOT covered unless listed in CORS_ORIGINS above (or add another regex here).
# Set to empty to disable: CORS_ORIGIN_REGEX=
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# --- Image uploads (Render wipes local disk on each deploy) ---
# Leave unset to use local ./uploads (fine for dev). For production, use Supabase Storage:
# 1) Dashboard → Storage → New bucket → name e.g. site-uploads → Public bucket ON
# 2) Project Settings → API → copy Project URL and service_role key (server only, never in frontend)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_STORAGE_BUCKET=site-uploads

# Optional: create default admin on startup if that email does not exist.
# SEED_DEFAULT_ADMIN=true
# DEFAULT_ADMIN_EMAIL=admin@example.com
# DEFAULT_ADMIN_PASSWORD=change-me
